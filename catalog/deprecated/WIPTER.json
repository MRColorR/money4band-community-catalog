{
  "name": "WIPTER",
  "dashboard": "https://wipter.com/dashboard",
  "compose_config": {
    "container_name": "${DEVICE_NAME}_wipter",
    "hostname": "${DEVICE_NAME}_wipter",
    "image": "ghcr.io/xterna/wipter",
    "environment": [
      "WIPTER_EMAIL=$WIPTER_EMAIL",
      "WIPTER_PASSWORD=$WIPTER_PASSWORD"
    ],
    "labels": [
      "com.centurylinklabs.watchtower.enable=true",
      "com.centurylinklabs.watchtower.scope=${M4B_WATCHTOWER_SCOPE}"
    ],
    "ports": [
      "${WIPTER_PORT_1}:5900",
      "${WIPTER_PORT_2}:6080"
    ],
    "restart": "always",
    "cpus": "${APP_CPU_LIMIT_MEDIUM}",
    "mem_reservation": "${APP_MEM_RESERV_MEDIUM}",
    "mem_limit": "${APP_MEM_LIMIT_MEDIUM}",
    "logging": {
      "driver": "json-file",
      "options": {
        "max-size": "10m",
        "max-file": "3"
      }
    }
  },
  "compose_config_proxy": {
    "network_mode": "service:proxy",
    "hostname": null,
    "ports": null
  },
  "flags": {
    "email": {},
    "password": {}
  },
  "install_limit": -1,
  "compose_layer": "residential",
