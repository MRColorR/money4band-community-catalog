{
  "name": "WIZARDGAIN",
  "dashboard": "https://wizardgain.com/dashboard",
  "compose_config": {
    "container_name": "${DEVICE_NAME}_wizardgain",
    "hostname": "${DEVICE_NAME}_wizardgain",
    "image": "wizardgain/worker:latest",
    "environment": [
      "EMAIL=${WIZARDGAIN_EMAIL}"
    ],
    "labels": [
      "com.centurylinklabs.watchtower.enable=true",
      "com.centurylinklabs.watchtower.scope=${M4B_WATCHTOWER_SCOPE}"
    ],
    "restart": "always",
    "cpus": "${APP_CPU_LIMIT_MEDIUM}",
    "mem_reservation": "${APP_MEM_RESERV_MEDIUM}",
    "mem_limit": "${APP_MEM_LIMIT_MEDIUM}",
    "logging": {
      "driver": "json-file",
      "options": {
        "max-size": "10m",
        "max-file": "3"
      }
    },
    "healthcheck": {
      "test": [
        "CMD-SHELL",
        "pgrep -f wizard || exit 1"
      ],
      "interval": "120s",
      "timeout": "10s",
      "retries": 3,
      "start_period": "60s"
    }
  },
  "compose_config_proxy": {
    "network_mode": "service:proxy",
    "hostname": null
  },
  "flags": {
    "email": {}
  },
  "install_limit": -1,
  "compose_layer": "universal",
  "app_details": {
    "official_name": "WizardGain",
    "publisher": "WizardGain",
    "official_url": "https://wizardgain.com",
    "tos_url": "undocumented",
    "status": "deprecated",
    "device_limits": {
      "max_devices_per_account": "undocumented",
      "max_devices_per_ip": 1,
      "max_ips_per_account": "undocumented",
      "notes": "Limited documentation. Other projects support it."
    },
    "ip_policy": {
      "residential": true,
      "datacenter": true,
      "vps": true,
      "vpn": "undocumented",
      "proxy": "undocumented",
      "mobile": "undocumented",
      "adjacent_ips_accepted": "undocumented",
      "adjacent_ips_max": "undocumented",
      "ipv6": "undocumented",
      "geo_restrictions": "none known",
      "quality_notes": "Limited available documentation."
    },
    "docker": {
      "image_official": true,
      "image_maintained": true,
      "last_update": "2025-12"
    },
    "earnings": {
      "model": "per-GB",
      "min_payout": "undocumented",
      "payout_methods": [
        "undocumented"
      ],
      "avg_monthly_residential_usd": "unknown",
      "avg_monthly_datacenter_usd": "unknown"
    },
    "warnings": [
      "Reported 522 errors in community",
      "Service stability unverified \u2014 use with caution"
    ],
    "confidence": "low",
    "sources": [],
    "last_verified": "2026-03-23",
    "compose_layer_reasoning": "Limited available documentation. Supported on DC/VPS by other projects.",
    "install_limit_reasoning": "Limited documentation. Other projects support it.",
    "recommendation": "promoted",
    "recommendation_reasoning": "Promoted to supported. Docker image verified on Docker Hub.",
    "confidence_notes": "Community reports service instability (522 errors).",
    "removal_history": "Removed 2026-05-15 due to persistent HTTP 522 errors at the service backend. IGM also flags WizardGain as dead in their tracking. Image wizardgain/worker still publishes but the upstream service is unreliable."
  },
  "referrals": [
    {
      "url": "https://wizardgain.com",
      "contributor": "MRColorR"
    }
  ],
  "user_config_template": {
    "enabled": false,
    "email": "yourWIZARDGAINMail"
  },
  "additional_details": "522 errors \u2014 service infrastructure unreliable"
}
