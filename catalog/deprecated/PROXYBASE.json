{
  "name": "PROXYBASE",
  "dashboard": "https://peer.proxybase.org/",
  "compose_config": {
    "container_name": "${DEVICE_NAME}_proxybase",
    "hostname": "${DEVICE_NAME}_proxybase",
    "image": "proxybase/proxybase:latest",
    "environment": [
      "USER_ID=$PROXYBASE_USERID",
      "DEVICE_NAME=${DEVICE_NAME}"
    ],
    "labels": [
      "com.centurylinklabs.watchtower.enable=true",
      "com.centurylinklabs.watchtower.scope=${M4B_WATCHTOWER_SCOPE}"
    ],
    "restart": "always",
    "cpus": "${APP_CPU_LIMIT_BIG}",
    "mem_reservation": "${APP_MEM_RESERV_BIG}",
    "mem_limit": "${APP_MEM_LIMIT_BIG}",
    "logging": {
      "driver": "json-file",
      "options": {
        "max-size": "10m",
        "max-file": "3"
      }
    },
    "healthcheck": {
      "test": [
        "CMD-SHELL",
        "pgrep -f proxybase || exit 1"
      ],
      "interval": "120s",
      "timeout": "10s",
      "retries": 3,
      "start_period": "60s"
    }
  },
  "compose_config_proxy": {
    "network_mode": "service:proxy",
    "hostname": null
  },
  "flags": {
    "userid": {}
  },
  "install_limit": -1,
  "compose_layer": "datacenter",
  "app_details": {
    "official_name": "ProxyBase",
    "publisher": "ProxyBase",
    "official_url": "https://proxybase.com",
    "tos_url": "undocumented",
    "status": "deprecated",
    "device_limits": {
      "max_devices_per_account": "undocumented",
      "max_devices_per_ip": "undocumented",
      "max_ips_per_account": "undocumented",
      "notes": "Service reportedly moved domains. Very sparse documentation. No reliable information found in 2025-2026 research."
    },
    "ip_policy": {
      "residential": "undocumented",
      "datacenter": "undocumented",
      "vps": "undocumented",
      "vpn": "undocumented",
      "proxy": "undocumented",
      "mobile": "undocumented",
      "adjacent_ips_accepted": "undocumented",
      "adjacent_ips_max": "undocumented",
      "ipv6": "undocumented",
      "geo_restrictions": "undocumented",
      "quality_notes": "Insufficient data to assess IP policy."
    },
    "docker": {
      "image_official": "unknown",
      "image_maintained": "unknown",
      "last_update": "unknown"
    },
    "earnings": {
      "model": "undocumented",
      "min_payout": "undocumented",
      "payout_methods": [
        "undocumented"
      ],
      "avg_monthly_residential_usd": "unknown",
      "avg_monthly_datacenter_usd": "unknown"
    },
    "warnings": [
      "Domain instability \u2014 service may have moved or shut down",
      "Zero accessible official documentation",
      "Verify service is alive before deploying"
    ],
    "confidence": "low",
    "sources": [],
    "last_verified": "2026-03-21",
    "compose_layer_reasoning": "Insufficient data to assess IP policy. Service domain instability prevents verification.",
    "install_limit_reasoning": "Zero accessible official documentation. No verified limits exist.",
    "recommendation": "re-evaluate",
    "recommendation_reasoning": "Domain instability and zero documentation. Verify service is alive before deploying. Consider deprecation.",
    "confidence_notes": "No accessible documentation or active service site found during research.",
