{
  "name": "DAWN",
  "dashboard": "https://dawninternet.com",
  "compose_config": {
    "container_name": "${DEVICE_NAME}_dawn",
    "hostname": "${DEVICE_NAME}_dawn",
    "image": "carbon2029/dockweb:latest",
    "environment": [
      "DAWN_EMAIL=$DAWN_EMAIL",
      "DAWN_PASS=$DAWN_PASSWORD"
    ],
    "volumes": [
      ".data/.dawn:/app/chrome_user_data"
    ],
    "ports": [
      "${DAWN_PORT}:5000"
    ],
    "labels": [
      "com.centurylinklabs.watchtower.enable=true",
      "com.centurylinklabs.watchtower.scope=${M4B_WATCHTOWER_SCOPE}"
    ],
    "restart": "always",
    "cpus": "${APP_CPU_LIMIT_BIG}",
    "mem_reservation": "${APP_MEM_RESERV_BIG}",
    "mem_limit": "${APP_MEM_LIMIT_BIG}",
    "logging": {
      "driver": "json-file",
      "options": {
        "max-size": "10m",
        "max-file": "3"
      }
    }
  },
  "compose_config_proxy": {
    "network_mode": "service:proxy",
    "hostname": null,
    "ports": null
  },
  "flags": {
    "email": {},
    "password": {}
  },
  "install_limit": -1,
  "compose_layer": "residential",
  "app_details": {
    "official_name": "Dawn Internet",
